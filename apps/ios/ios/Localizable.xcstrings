    "guard.categoryFooter" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فئات التهديد تحتسب ضد نقاط الحارس. الفئات الآمنة تحسّنها. الفئات المحايدة مستثناة. الفئات الاجتماعية مقفلة كتهديدات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Threat categories count against your Guard Score. Safe categories improve it. Neutral categories are excluded. Social categories are locked as threats."
          }
        }
      }
    },
