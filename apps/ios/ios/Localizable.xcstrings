    "ban.accountRestrictedMessage": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تقييد حسابك من الوصول إلى التطبيق."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account has been restricted from accessing the application."
          }
        }
      }
    },
    "ban.appealInfo": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا كنت تعتقد أن هذا القيد تم تطبيقه عن طريق الخطأ، يرجى التواصل مع فريق الدعم للحصول على المساعدة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you believe this restriction was applied in error, please contact our support team for assistance."
          }
        }
      }
    },
