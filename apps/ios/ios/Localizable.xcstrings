      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإنجاز هو عدد الأيام المتتالية التي حافظت فيها على التزامك. كل يوم يمر بدون انتكاسة يضيف إلى إنجازك."
