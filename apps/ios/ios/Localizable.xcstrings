    "guard.screenTimeDescription" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امنح إذن وقت الشاشة ليتمكن الحارس من عرض استخدامك اليومي ومساعدتك على البقاء في المسار الصحيح."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grant Screen Time access so Guard can show your daily usage and help you stay on track."
